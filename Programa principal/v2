using System;
using System.Collections.Generic;

namespace LigaDeportiva
{
    class Program
    {
        // 1. APLICAMOS ENUMS (Visto en Programa 5 del repo de prácticas)
        enum CategoriasLiga
        {
            Infantiles = 1,
            Cadetes = 2,
            Juveniles = 3,
            Primera = 4,
            Veteranos = 5
        }

        // 2. APLICAMOS STRUCTS (Visto en Programa 7 del repo de prácticas)
        struct Equipo
        {
            public string NombreClub;
            public string NombreCompleto;
            public int Categoria; 
            public int CantidadJugadores;
        }

        struct Jugador
        {
            public int DNI;
            public string Nombre;
            public string Apellido;
            public int Edad;
            public string NombreEquipo;
            public bool Seguro;
            public bool Afiliacion;
        }

        static List<Equipo> listaEquipos = new List<Equipo>();
        static List<Jugador> listaJugadores = new List<Jugador>();
        
        static void Main(string[] args)
        {
            int opcion = -1;
            
            // Bucle DO-WHILE visto en Programa 11
            do
            {
                Console.Clear();
                Console.WriteLine("--- LIGA DEPORTIVA ---");
                Console.WriteLine("1. Alta de Equipo");
                Console.WriteLine("2. Alta de Jugador");
                Console.WriteLine("3. Listar Jugadores Asegurados");
                Console.WriteLine("4. Reportes de Edades");
                Console.WriteLine("5. Equipos Incompletos");
                Console.WriteLine("0. Salir");
                Console.Write("Opcion: ");

                opcion = int.Parse(Console.ReadLine());

                // Estructura SWITCH vista en Programa 12
                switch (opcion)
                {
                    case 1:
                        AltaEquipo();
                        break;
                    case 2:
                        AltaJugador();
                        break;
                    case 3:
                        ListarAsegurados();
                        break;
                    case 4:
                        ReportesEdades();
                        break;
                    case 5:
                        EquiposIncompletos();
                        break;
                    case 0:
                        Console.WriteLine("Saliendo...");
                        break;
                    default:
                        Console.WriteLine("Opcion incorrecta");
                        Console.ReadLine();
                        break;
                }
            } while (opcion != 0);
        }

        static void AltaEquipo()
        {
            Console.Clear();
            Console.WriteLine("--- ALTA DE EQUIPO ---");
            
            Console.Write("Ingrese el nombre del Club (Ej: Club Norte): ");
            string nombreClub = Console.ReadLine();

            Console.WriteLine("Categorias:");
            Console.WriteLine("1. Infantiles (h/13)");
            Console.WriteLine("2. Cadetes (14-16)");
            Console.WriteLine("3. Juveniles (17-18)");
            Console.WriteLine("4. Primera (19-34)");
            Console.WriteLine("5. Veteranos (+35)");
            Console.Write("Seleccione categoria (1-5): ");
            int catSeleccionada = int.Parse(Console.ReadLine());

            if (catSeleccionada < 1 || catSeleccionada > 5)
            {
                Console.WriteLine("Error: Categoria Invalida");
                Console.ReadLine();
                return;
            }

            int cantidadExistentes = 0;
            
            // FOR clásico visto en Programa 11
            for (int i = 0; i < listaEquipos.Count; i++)
            {
                // Validación con && vista en Programa 4
                if (listaEquipos[i].NombreClub == nombreClub && listaEquipos[i].Categoria == catSeleccionada)
                {
                    cantidadExistentes++;
                }
            }

            // SIMPLIFICACIÓN: Usamos un arreglo de strings en lugar de matemáticas de ASCII
            string[] letras = { "A", "B", "C", "D", "E", "F", "G" };
            string letraSufijo = letras[cantidadExistentes];

            // Instanciación del struct igual al Programa 7 (Persona P1; P1.Altura = 180;)
            Equipo nuevoEquipo;
            nuevoEquipo.NombreClub = nombreClub;
            
            // Interpolación de strings vista en Programa 7 y 8
            nuevoEquipo.NombreCompleto = $"{nombreClub} {letraSufijo}";
            nuevoEquipo.Categoria = catSeleccionada;
            nuevoEquipo.CantidadJugadores = 0;

            listaEquipos.Add(nuevoEquipo);
            
            Console.WriteLine($"Equipo registrado: {nuevoEquipo.NombreCompleto}");
            Console.ReadLine();
        }

        static void AltaJugador()
        {
            Console.Clear();
            Console.WriteLine("--- ALTA DE JUGADOR ---");

            if (listaEquipos.Count == 0)
            {
                Console.WriteLine("Primero debe cargar equipos.");
                Console.ReadLine();
                return;
            }

            Jugador j; // Struct vacío

            Console.Write("Ingrese DNI: ");
            j.DNI = int.Parse(Console.ReadLine());

            // Validar DNI
            for (int i = 0; i < listaJugadores.Count; i++)
            {
                if (listaJugadores[i].DNI == j.DNI)
                {
                    Console.WriteLine("El DNI ya existe.");
                    Console.ReadLine();
                    return;
                }
            }

            Console.Write("Nombre: ");
            j.Nombre = Console.ReadLine();
            Console.Write("Apellido: ");
            j.Apellido = Console.ReadLine();
            Console.Write("Edad: ");
            j.Edad = int.Parse(Console.ReadLine());

            Console.WriteLine("Seleccione el equipo por numero:");
            for (int i = 0; i < listaEquipos.Count; i++)
            {
                // Usamos el casteo del Enum para mostrar el nombre de la categoria (Ej. Programa 5)
                CategoriasLiga nombreCat = (CategoriasLiga)listaEquipos[i].Categoria;
                Console.WriteLine($"{i + 1}. {listaEquipos[i].NombreCompleto} ({nombreCat})");
            }
            int indiceEq = int.Parse(Console.ReadLine()) - 1;

            if (indiceEq < 0 || indiceEq >= listaEquipos.Count)
            {
                Console.WriteLine("Equipo no existe.");
                Console.ReadLine();
                return;
            }

            int catDelEquipo = listaEquipos[indiceEq].Categoria;
            bool edadValida = false;

            // Logica de ifs anidados simple
            if (catDelEquipo == 1 && j.Edad <= 13) edadValida = true;
            else if (catDelEquipo == 2 && j.Edad >= 14 && j.Edad <= 16) edadValida = true;
            else if (catDelEquipo == 3 && j.Edad >= 17 && j.Edad <= 18) edadValida = true;
            else if (catDelEquipo == 4 && j.Edad >= 19 && j.Edad <= 34) edadValida = true;
            else if (catDelEquipo == 5 && j.Edad >= 35) edadValida = true;

            if (edadValida == false)
            {
                Console.WriteLine("La edad no corresponde a la categoria.");
                Console.ReadLine();
                return;
            }

            j.NombreEquipo = listaEquipos[indiceEq].NombreCompleto;

            Console.Write("Tiene seguro? (SI/NO): ");
            string respSeguro = Console.ReadLine();
            if (respSeguro == "SI") j.Seguro = true; else j.Seguro = false;

            Console.Write("Tiene afiliacion? (SI/NO): ");
            string respAfil = Console.ReadLine();
            if (respAfil == "SI") j.Afiliacion = true; else j.Afiliacion = false;

            listaJugadores.Add(j);

            // Sumamos el contador usando una variable auxiliar
            Equipo eqAux = listaEquipos[indiceEq];
            eqAux.CantidadJugadores++;
            listaEquipos[indiceEq] = eqAux;

            Console.WriteLine("Jugador Guardado!");
            Console.ReadLine();
        }

        static void ListarAsegurados()
        {
            Console.Clear();
            Console.WriteLine("--- ASEGURADOS ---");
            for (int i = 0; i < listaJugadores.Count; i++)
            {
                if (listaJugadores[i].Seguro == true)
                {
                    Console.WriteLine($"{listaJugadores[i].Nombre} - {listaJugadores[i].NombreEquipo}");
                }
            }
            Console.ReadLine();
        }

        static void ReportesEdades()
        {
            Console.Clear();
            if (listaJugadores.Count == 0) return;

            int min = 999;
            int max = -1;
            int suma = 0;
            string nomMin = "";
            string nomMax = "";

            for (int i = 0; i < listaJugadores.Count; i++)
            {
                suma = suma + listaJugadores[i].Edad;

                if (listaJugadores[i].Edad < min)
                {
                    min = listaJugadores[i].Edad;
                    nomMin = listaJugadores[i].Nombre;
                }
                if (listaJugadores[i].Edad > max)
                {
                    max = listaJugadores[i].Edad;
                    nomMax = listaJugadores[i].Nombre;
                }
            }

            double promedio = (double)suma / listaJugadores.Count;

            Console.WriteLine($"Joven: {nomMin} ({min})");
            Console.WriteLine($"Viejo: {nomMax} ({max})");
            Console.WriteLine($"Promedio: {promedio}");
            Console.ReadLine();
        }

        static void EquiposIncompletos()
        {
            Console.Clear();
            Console.WriteLine("--- EQUIPOS INCOMPLETOS ---");
            for (int i = 0; i < listaEquipos.Count; i++)
            {
                int cat = listaEquipos[i].Categoria;
                int jug = listaEquipos[i].CantidadJugadores;

                if (cat == 5 && jug < 10)
                {
                    Console.WriteLine($"{listaEquipos[i].NombreCompleto} tiene {jug}. Faltan para 10.");
                }
                else if (cat != 5 && jug < 9)
                {
                    Console.WriteLine($"{listaEquipos[i].NombreCompleto} tiene {jug}. Faltan para 9.");
                }
            }
            Console.ReadLine();
        }
    }
}
